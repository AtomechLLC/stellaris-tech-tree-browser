{
  "name": "stellaris-tech-tree-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Frontend SPA: renders the Stellaris tech tree from the pipeline's tech.json snapshot.",
  "scripts": {
    "copy-data": "node scripts/copy-data.mjs",
    "predev": "npm run copy-data",
    "prebuild": "npm run copy-data",
    "pretest": "npm run copy-data",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "test": "vitest run",
    "lint:types": "tsc --noEmit"
  },
  "dependencies": {
    "@react-sigma/core": "5.0.6",
    "@sigma/node-border": "3.0.0",
    "@sigma/node-image": "3.0.0",
    "elkjs": "0.11.1",
    "fflate": "^0.8.3",
    "graphology": "0.26.0",
    "jomini": "^0.10.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sigma": "3.0.3",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "5.9.3",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  }
}
